{
  "dashboard": {
    "title": "SquadOps WarmBoot Telemetry",
    "tags": ["squadops", "warmboot", "sip-027"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 1,
    "refresh": "15s",
    "panels": [
      {
        "id": 1,
        "title": "Task Duration by ECID",
        "type": "graph",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(task_duration_seconds_bucket[5m]))",
            "legendFormat": "P95 Duration",
            "refId": "A"
          },
          {
            "expr": "rate(task_duration_seconds_sum[5m]) / rate(task_duration_seconds_count[5m])",
            "legendFormat": "Avg Duration",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "id": 2,
        "title": "Token Usage by Agent",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (agent) (rate(agent_tokens_used_total[5m]))",
            "legendFormat": "{{agent}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "id": 3,
        "title": "System Resources",
        "type": "graph",
        "targets": [
          {
            "expr": "system_cpu_usage_percent",
            "legendFormat": "CPU %",
            "refId": "A"
          },
          {
            "expr": "system_memory_usage_percent",
            "legendFormat": "Memory %",
            "refId": "B"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "id": 4,
        "title": "Task Success/Failure Rate",
        "type": "graph",
        "targets": [
          {
            "expr": "sum by (status) (rate(task_status_total[5m]))",
            "legendFormat": "{{status}}",
            "refId": "A"
          }
        ],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "variables": [
      {
        "name": "ecid",
        "type": "query",
        "query": "label_values(agent_tokens_used_total, ecid)",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "agent",
        "type": "query",
        "query": "label_values(agent_tokens_used_total, agent)",
        "current": {
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  }
}

