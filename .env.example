# SquadOps Environment Variable Overrides
# Copy this file to .env and modify as needed
# Environment variables use SQUADOPS__ prefix with double underscores for nesting
# Example: SQUADOPS__DB__POOL__SIZE=10 maps to db.pool.size

# Profile Selection
# SQUADOPS_PROFILE=local  # Options: local, dev, stage, prod

# Strict Configuration Mode
# SQUADOPS_STRICT_CONFIG=true  # Enable strict validation (errors on unknown keys)

# Database Configuration
# SQUADOPS__DB__URL=postgresql://user:password@host:5432/dbname
# SQUADOPS__DB__POOL__SIZE=10
# SQUADOPS__DB__MAX__OVERFLOW=20

# RabbitMQ Configuration
# SQUADOPS__COMMS__RABBITMQ__URL=amqp://user:password@host:5672/vhost
# SQUADOPS__COMMS__RABBITMQ__HOST=rabbitmq
# SQUADOPS__COMMS__RABBITMQ__PORT=5672
# SQUADOPS__COMMS__RABBITMQ__USER=squadops

# Redis Configuration
# SQUADOPS__COMMS__REDIS__URL=redis://host:6379/0
# SQUADOPS__COMMS__REDIS__HOST=redis
# SQUADOPS__COMMS__REDIS__PORT=6379

# Runtime API
# SQUADOPS__RUNTIME__API__URL=http://runtime-api:8001

# Prefect Configuration
# SQUADOPS__PREFECT__API__URL=http://prefect-server:4200/api

# LLM Configuration
# SQUADOPS__LLM__URL=http://localhost:11434
# SQUADOPS__LLM__MODEL=llama3.1:8b
# SQUADOPS__LLM__USE__LOCAL=true
# SQUADOPS__LLM__TIMEOUT=60

# Agent Configuration
# SQUADOPS__AGENT__ID=my_agent
# SQUADOPS__AGENT__ROLE=lead
# SQUADOPS__AGENT__DISPLAY__NAME=My Agent

# Cycle Data Configuration
# SQUADOPS__CYCLE__DATA__ROOT=/path/to/cycle_data

# Telemetry Configuration
# SQUADOPS__TELEMETRY__BACKEND=opentelemetry
# SQUADOPS__TELEMETRY__OTLP_ENDPOINT=http://localhost:4317
# SQUADOPS__TELEMETRY__PROMETHEUS_PORT=8888

# Observability (for health-check service)
# SQUADOPS__OBSERVABILITY__PROMETHEUS__URL=http://prometheus:9090
# SQUADOPS__OBSERVABILITY__GRAFANA__URL=http://grafana:3000
# SQUADOPS__OBSERVABILITY__OTEL__URL=http://otel-collector:4318
# SQUADOPS__OBSERVABILITY__OTEL__HEALTH_URL=http://otel-collector:13133
# SQUADOPS__OBSERVABILITY__OTEL__ZPAGES_URL=http://otel-collector:55679

# Agent Lifecycle Configuration
# SQUADOPS__AGENT__INSTANCES_FILE=agents/instances/instances.yaml
# SQUADOPS__AGENT__HEARTBEAT_TIMEOUT_WINDOW=90
# SQUADOPS__AGENT__RECONCILIATION_INTERVAL=45

# Deployment Tooling Configuration
# SQUADOPS__DEPLOYMENT__FILE_MANAGER__ALLOWED_EXTENSIONS=.md,.py,.js
# SQUADOPS__DEPLOYMENT__FILE_MANAGER__MAX_FILE_SIZE=10485760
# SQUADOPS__DEPLOYMENT__DOCKER__NETWORK_NAME=squad-ops_squadnet
# SQUADOPS__DEPLOYMENT__DOCKER__DEFAULT_PORT=8080
# SQUADOPS__DEPLOYMENT__DOCKER__RESTART_POLICY=unless-stopped
# SQUADOPS__DEPLOYMENT__WARM_BOOT_DIR=/app/warm-boot
