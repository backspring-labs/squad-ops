{
  "realm": "squadops-dev",
  "displayName": "SquadOps Dev",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "eventsEnabled": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full administrative access to SquadOps",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "operator",
        "description": "Operational access — start/stop cycles, manage tasks",
        "composite": false,
        "clientRole": false
      },
      {
        "name": "viewer",
        "description": "Read-only access to dashboards and status",
        "composite": false,
        "clientRole": false
      }
    ],
    "client": {
      "squadops-runtime": [
        {
          "name": "admin",
          "description": "Full administrative access via runtime API",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "operator",
          "description": "Operational access via runtime API",
          "composite": false,
          "clientRole": true
        },
        {
          "name": "viewer",
          "description": "Read-only access via runtime API",
          "composite": false,
          "clientRole": true
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "squadops-console",
      "name": "SquadOps Console",
      "description": "Public client for the SquadOps web console (PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "rootUrl": "http://localhost:4040",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:4040/*",
        "http://localhost:3000/*",
        "http://localhost:3001/*",
        "http://localhost:8000/*"
      ],
      "webOrigins": [
        "http://localhost:4040",
        "http://localhost:3000",
        "http://localhost:3001",
        "http://localhost:8000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      },
      "protocolMappers": [
        {
          "name": "runtime-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "squadops-runtime",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "squadops-runtime",
      "name": "SquadOps Runtime API",
      "description": "Confidential client for service-to-service authentication",
      "enabled": true,
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "secret": "squadops-runtime-secret",
      "protocolMappers": [
        {
          "name": "runtime-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "squadops-runtime",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "squadops-cli",
      "name": "SquadOps CLI",
      "description": "Public client for CLI authentication (password grant + device flow)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true"
      },
      "protocolMappers": [
        {
          "name": "runtime-api-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "squadops-runtime",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "users": [
    {
      "username": "squadops-admin",
      "email": "admin@squadops.local",
      "emailVerified": true,
      "enabled": true,
      "firstName": "SquadOps",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "operator",
        "viewer"
      ]
    }
  ],
  "scopeMappings": [],
  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "roles"
  ]
}
