{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentRequest",
  "type": "object",
  "required": ["action", "payload", "metadata"],
  "properties": {
    "action": {
      "type": "string",
      "description": "Capability name from catalog (e.g., build.artifact, test.run, validate.warmboot)",
      "pattern": "^[a-z]+\\.[a-z_]+$"
    },
    "payload": {
      "type": "object",
      "description": "Free-form object with keys like project, component, ref, etc.",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "required": ["pid", "ecid"],
      "properties": {
        "pid": {
          "type": "string",
          "description": "Process ID"
        },
        "ecid": {
          "type": "string",
          "description": "Execution Cycle ID"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Optional labels"
        }
      },
      "additionalProperties": true
    }
  }
}

