{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentResponse",
  "type": "object",
  "required": ["status", "result", "timing"],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["ok", "error"],
      "description": "Response status"
    },
    "result": {
      "type": "object",
      "description": "Result object with keys matching capability catalog result schema",
      "additionalProperties": true
    },
    "error": {
      "type": "object",
      "description": "Error details (only present when status is 'error')",
      "properties": {
        "code": {
          "type": "string",
          "description": "Error code"
        },
        "message": {
          "type": "string",
          "description": "Error message"
        },
        "retryable": {
          "type": "boolean",
          "description": "Whether the error is retryable"
        }
      }
    },
    "idempotency_key": {
      "type": "string",
      "description": "Hash of agent_id, action, payload, and metadata.pid"
    },
    "timing": {
      "type": "object",
      "required": ["started_at", "ended_at"],
      "properties": {
        "started_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when request started"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO-8601 timestamp when request completed"
        }
      }
    }
  }
}

